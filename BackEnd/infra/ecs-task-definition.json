{
  "_comment": "ECS Task Definition for cloudgraph-api Fargate service. Deploy via ecs-deploy.sh.",
  "family": "cloudgraph-api",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "512",
  "memory": "1024",

  "_roleComment": "executionRoleArn: needs ecr:GetAuthorizationToken, ecr:BatchGetImage, logs:CreateLogStream, logs:PutLogEvents, secretsmanager:GetSecretValue. taskRoleArn: needs s3:PutObject, s3:GetObject, s3:ListBucket on the uploads bucket, lambda:InvokeFunction for clustering_processor, and rds-db:connect if using IAM DB auth.",
  "executionRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/cloudgraph-ecs-execution-role",
  "taskRoleArn":      "arn:aws:iam::YOUR_ACCOUNT_ID:role/cloudgraph-ecs-task-role",

  "containerDefinitions": [
    {
      "name": "cloudgraph-api",
      "image": "YOUR_ECR_URI/cloudgraph-backend:latest",
      "essential": true,

      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],

      "_envComment": "Do not put secrets in 'environment'. Use 'secrets' below — values are injected from AWS Secrets Manager at container start time.",
      "environment": [],

      "secrets": [
        {
          "name": "S3_BUCKET_NAME",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:cloudgraph/S3_BUCKET_NAME"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:cloudgraph/DATABASE_URL"
        },
        {
          "name": "COGNITO_REGION",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:cloudgraph/COGNITO_REGION"
        },
        {
          "name": "COGNITO_USER_POOL_ID",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:cloudgraph/COGNITO_USER_POOL_ID"
        },
        {
          "name": "COGNITO_APP_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:cloudgraph/COGNITO_APP_CLIENT_ID"
        },
        {
          "name": "AWS_REGION",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:cloudgraph/AWS_REGION"
        },
        {
          "name": "AWS_LAMBDA_FUNCTION_NAME",
          "valueFrom": "arn:aws:secretsmanager:YOUR_REGION:YOUR_ACCOUNT_ID:secret:cloudgraph/AWS_LAMBDA_FUNCTION_NAME"
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cloudgraph-api",
          "awslogs-region": "YOUR_REGION",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
