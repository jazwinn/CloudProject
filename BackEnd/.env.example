# ─────────────────────────────────────────────────────────────────────────────
# CloudGraph Backend — Environment Configuration
#
# On ECS Fargate, AWS credentials are injected automatically via the Task IAM
# Role. Do NOT add AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here — they are
# not needed and would be a security risk.
#
# For local development, authenticate via:
#   Option A: aws sso login --profile <your-profile>
#   Option B: aws configure (creates ~/.aws/credentials with a named profile)
#
# Then boto3 will automatically pick up credentials from the environment.
# ─────────────────────────────────────────────────────────────────────────────

# AWS Configuration
AWS_REGION="us-east-1"
S3_BUCKET_NAME="cloudgraph-uploads"
AWS_LAMBDA_FUNCTION_NAME="cloudgraph-cluster-processor"

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/cloudgraph"

# Amazon Cognito Configuration
COGNITO_REGION="us-east-1"
COGNITO_USER_POOL_ID="us-east-1_xxxxx"
COGNITO_APP_CLIENT_ID="xxxxxxxxx"
